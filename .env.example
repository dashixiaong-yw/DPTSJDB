# 硅基流动（SiliconFlow）OCR API 配置
# 注册获取 API Key：https://siliconflow.cn
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# 默认视觉模型（moonshot-v1-vision-preview 已停用）
# 推荐使用 qwen-vl-plus（价格最低）或 llava-1.5-7b
KIMI_VISION_MODEL=qwen-vl-plus
# 备用模型列表（逗号分隔，按价格从低到高排序）
# 可用模型: qwen-vl-plus, llava-1.5-7b, qwen-vl-max, cogvlm-chat, qwen-vl-turbo
BACKUP_VISION_MODELS=llava-1.5-7b,qwen-vl-max,cogvlm-chat

# 硅基流动（SiliconFlow）OCR API 配置
# 注册获取 API Key：https://siliconflow.cn
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# 主视觉模型（识别精度最高，推荐 Qwen3-VL-32B）
# 可用视觉模型：Qwen/Qwen3-VL-32B-Instruct, Qwen/Qwen3-VL-8B-Instruct,
#   Qwen/Qwen3-VL-30B-A3B-Instruct, PaddlePaddle/PaddleOCR-VL-1.5(免费),
#   deepseek-ai/DeepSeek-OCR, zai-org/GLM-4.5V
# 已下架模型（403）：Qwen2.5-VL-72B-Instruct, Pro/Qwen2.5-VL-7B-Instruct
KIMI_VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct
# 备用模型列表（逗号分隔，按价格从低到高排序）
# PaddleOCR-VL-1.5 免费，Qwen3-VL-8B 最便宜，Qwen3-VL-30B-A3B 性价比高
BACKUP_VISION_MODELS=Qwen/Qwen3-VL-8B-Instruct,Qwen/Qwen3-VL-30B-A3B-Instruct,PaddlePaddle/PaddleOCR-VL-1.5
